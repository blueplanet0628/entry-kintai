// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SHOP_ADMIN
  USER
}

enum EmploymentStatus {
  PART_TIME
  FULL_TIME
  TEMPORARY
  SUBCONTRACTING
}

enum Gender {
  MALE
  FEMALE
}

enum Wage {
  HOURLY
  DAILY
  MONTHLY
}

enum FareSetting {
  DAILY
  MONTHLY
  NON
}

enum BankAccountType {
  SAVING
  CHECKING
}

model Company {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(255)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamp(0)

  shops  Shop[]
  users  User[]

  @@map("companies")
}

model Shop {
  id                 Int        @id @default(autoincrement())
  companyId          Int        @map("company_id")
  code               String     @db.VarChar(10)
  type               Int        @db.TinyInt()
  name               String     @db.VarChar(255)
  phoneNumber1       String     @db.VarChar(13) @map("phone_number1")
  phoneNumber2       String?    @db.VarChar(13) @map("phone_number2")
  phoneNumber3       String?    @db.VarChar(13) @map("phone_number3")
  phoneNumber4       String?    @db.VarChar(13) @map("phone_number4")
  addressPostcode    String     @db.VarChar(8) @map("address_postcode")
  addressPrefecture  String     @db.VarChar(8) @map("address_prefecture")
  addressCity        String     @db.VarChar(255) @map("address_city")
  addressBlock       String     @db.VarChar(255) @map("address_block")
  addressBuilding    String?    @db.VarChar(255) @map("address_building")
  shiftPeriod        Int        @db.TinyInt() @map("shift_period")
  shiftDeadline      Int        @db.SmallInt() @map("shift_deadline")
  isEnabled          Boolean    @db.TinyInt() @map("is_enabled")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt          DateTime?  @map("deleted_at") @db.Timestamp(0)

  shopUsers          ShopUser[]
  attendances        Attendance[]
  fareBetweenShops   FareBetweenShop[]

  company            Company    @relation(fields: [companyId], references: [id])

  @@map("shops")
}

model User {
  id             Int        @id @default(autoincrement())
  companyId      Int        @map("company_id")
  name           String?    @db.VarChar(255)
  email          String     @unique
  password       String     @db.VarChar(255)
  cardid         String?    @db.VarChar(255) @unique
  role           Role       @default(USER)
  isEnabled      Boolean    @db.TinyInt() @map("is_enabled")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamp(0)

  userDetails    UserDetail[]
  shopUsers      ShopUser[]
  attendances    Attendance[]

  company        Company    @relation(fields: [companyId], references: [id])

  @@map("users")
}

model UserDetail {
  id                   Int               @id @default(autoincrement())
  userId               Int               @map("user_id")
  employmentStatus     EmploymentStatus  @map("employment_status")
  lastName             String            @db.VarChar(255) @map("last_name")
  firstName            String            @db.VarChar(255) @map("first_name")
  lastNameKana         String            @db.VarChar(255) @map("last_name_kana")
  firstNameKana        String            @db.VarChar(255) @map("first_name_kana")
  nickname             String?           @db.VarChar(255)
  addressPostcode      String            @db.VarChar(8) @map("address_postcode")
  addressPrefecture    String            @db.VarChar(8) @map("address_prefecture")
  addressCity          String            @db.VarChar(255) @map("address_city")
  addressBlock         String            @db.VarChar(255) @map("address_block")
  addressBuilding      String?           @db.VarChar(255) @map("address_building")
  phoneNumber1         String            @db.VarChar(13) @map("phone_number1")
  phoneNumber2         String?           @db.VarChar(13) @map("phone_number2")
  birthday             DateTime          @db.Date
  gender               Gender        
  employeeCode         String            @db.VarChar(10) @map("employee_code")
  startDate            DateTime?         @db.Date @map("start_date")
  lastDate             DateTime?         @db.Date @map("last_date")
  retirementReason     String?           @db.Text @map("retirement_reason")
  wage                 Wage?
  timeframe1StartTime  DateTime?         @db.Time(3) @map("timeframe1_start_time")
  timeframe1EndTime    DateTime?         @db.Time(3) @map("timeframe1_end_time")
  timeframe1Salary     Int?              @map("timeframe1_salary") @default(0)
  timeframe2StartTime  DateTime?         @db.Time(3) @map("timeframe2_start_time")
  timeframe2EndTime    DateTime?         @db.Time(3) @map("timeframe2_end_time")
  timeframe2Salary     Int?              @map("timeframe2_salary") @default(0)
  timeframe3StartTime  DateTime?         @db.Time(3) @map("timeframe3_start_time")
  timeframe3EndTime    DateTime?         @db.Time(3) @map("timeframe3_end_time")
  timeframe3Salary     Int?              @map("timeframe3_salary") @default(0)
  fareSetting          FareSetting?      @map("fare_setting")
  dailyRate            Int?              @map("daily_rate") @default(0)
  fixedMonth           Int?              @map("fixed_month") @default(0)
  nonPayment           Int?              @map("non_payment") @default(0)
  bankName             String?           @db.VarChar(255) @map("bank_name")
  bankCode             String?           @db.Char(4) @map("bank_code")
  bankBranchName       String?           @db.VarChar(255) @map("bank_branch_name")
  bankBranchCode       String?           @db.Char(3) @map("bank_branch_code")
  bankAccountType      BankAccountType?  @map("bank_account_type")
  bankAccountNumber    String?           @db.Char(10) @map("bank_account_number")
  bankAccountHolder    String?           @db.VarChar(255) @map("bank_account_holder")
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt            DateTime?         @map("deleted_at") @db.Timestamp(0)

  user                 User              @relation(fields: [userId], references: [id])

  @@map("user_details")
}

model ShopUser {
  shopId     Int        @map("shop_id")
  userId     Int        @map("user_id")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamp(0)

  shop       Shop       @relation(fields: [shopId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@id([shopId, userId])

  @@map("shop_user")
}

model Attendance {
  id         Int        @id @default(autoincrement())
  shopId     Int        @map("shop_id")
  userId     Int        @map("user_id")
  clockIn1   DateTime?  @map("clock_in1") @db.DateTime(3)
  clockOut1  DateTime?  @map("clock_out1") @db.DateTime(3)
  clockIn2   DateTime?  @map("clock_in2") @db.DateTime(3)
  clockOut2  DateTime?  @map("clock_out2") @db.DateTime(3)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamp(0)

  shop       Shop       @relation(fields: [shopId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@map("attendances")
}

model FareBetweenShop {
  id         Int        @id @default(autoincrement())
  shop1Id    Int        @map("shop1_id")
  shop2Id    Int        @map("shop2_id")
  fare       Int?       @default(0)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamp(0)

  shop1      Shop       @relation(fields: [shop1Id], references: [id])

  @@unique([shop1Id, shop2Id])

  @@map("fare_between_shops")
  }
