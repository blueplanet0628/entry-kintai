// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// TODO: リレーションは後日実装予定.
model Shop {
  id                 Int        @id                     @default(autoincrement())
  companyId          Int        @map("company_id")
  code               String     @db.VarChar(10)
  type               Int        @db.TinyInt()
  name               String     @db.VarChar(255)
  phoneNumber1       String     @db.VarChar(13)         @map("phone_number1")
  phoneNumber2       String?    @db.VarChar(13)         @map("phone_number2")       // @default(NULL)
  phoneNumber3       String?    @db.VarChar(13)         @map("phone_number3")       // @default(NULL)
  phoneNumber4       String?    @db.VarChar(13)         @map("phone_number4")       // @default(NULL)
  addressPostcode    String     @db.VarChar(8)          @map("address_postcode")
  addressPrefecture  String     @db.VarChar(8)          @map("address_prefecture")
  addressCity        String     @db.VarChar(255)        @map("address_city")
  addressBlock       String     @db.VarChar(255)        @map("address_block")
  addressBuilding    String?    @db.VarChar(255)        @map("address_building")    // @default(NULL)
  shiftPeriod        Int        @db.TinyInt()           @map("shift_period")
  shiftDeadline      Int        @map("shift_deadline")
  isEnabled          Boolean    @map("is_enabled")  @db.TinyInt()
  createdAt          DateTime   @default(now())         @map("created_at")
  updatedAt          DateTime   @default(now())         @updatedAt                  @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")      // @default(NULL)
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  password            String  // ここに追加  
  image               String?
  accounts            Account[]
  sessions            Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}